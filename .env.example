# Copy to .env (gitignored) and fill in. NEVER commit real values.
# config.py reads secrets from the environment only — never from yaml.

# FMP — candidate data source (rotated Ultimate-plan key). Never the gold.
FMP_API_KEY=

# Daloopa MCP — gold reference layer (read-only scope). Delayed; optional until M6.
DALOOPA_MCP_URL=
DALOOPA_MCP_TOKEN=

# Anthropic — metered API key for headless Claude Code at scale (not a Max/Pro sub).
ANTHROPIC_API_KEY=

# Live-call gate. Unset = mocked/snapshot only. Set to 1 to allow live network in tests/smoke.
FINSKILL_ALLOW_LIVE=
