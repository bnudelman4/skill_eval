# Copy this to .env and fill in the values. Never commit .env.
# (.env is gitignored.)

# ── Required for the verifier (SEC EDGAR is free, no key needed) ──────────
# FMP — candidate data source (what the skill under test queries)
FMP_API_KEY=

# Anthropic — only needed for metered runs (the project also supports Max-sub auth)
ANTHROPIC_API_KEY=

# ── Required for the Daloopa gold path + paired A/B (Tier 1 next-step) ────
# Get a token from app.daloopa.com -> Account Settings / API / Integrations.
# URL may differ; check the dashboard or docs.daloopa.com.
DALOOPA_MCP_URL=https://mcp.daloopa.com
DALOOPA_TOKEN=
